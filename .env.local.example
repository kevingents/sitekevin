# --- Contactformulier (Resend) ---
# Gratis tier: 100 mails/dag. Maak een key op https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Afzender. Moet een geverifieerd domein zijn in Resend, bv. "Willie <hallo@jouwdomein.nl>"
# Tot je domein geverifieerd is werkt "onboarding@resend.dev".
RESEND_FROM_EMAIL=Willie <onboarding@resend.dev>

# Waar inzendingen heen gaan
CONTACT_TO_EMAIL=kevin@gents.nl

# Volledige URL van de live site (voor canonical/OG/sitemap)
NEXT_PUBLIC_SITE_URL=https://www.kevinvanwilligenburg.nl

# Optioneel: Cal.com link voor de demo-planner op /contact (bv. "kevin/kennismaking")
NEXT_PUBLIC_CAL_LINK=

# Optioneel: WhatsApp nummer in internationaal formaat zonder +, bv. 31612345678
NEXT_PUBLIC_WHATSAPP=

# --- Beeldgeneratie (alleen lokaal nodig, niet in Vercel) ---
# fal.ai key om hero-/sfeerbeelden te genereren: `node scripts/generate-images.mjs`
# Haal een key op https://fal.ai/dashboard/keys
FAL_KEY=
